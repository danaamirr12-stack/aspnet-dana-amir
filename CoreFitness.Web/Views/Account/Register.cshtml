@model CoreFitness.Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Sign Up";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-box">

        <h2>Become a Member</h2>
        <p>Sign up to access all fitness tools, track your membership, and connect with the community that supports your goals.</p>

        <div class="auth-social">
            <a href="#">G</a>
            <a href="#">f</a>
            <a href="#">in</a>
        </div>

        <div class="auth-divider">
            <hr />
            <span>OR USE EMAIL</span>
            <hr />
        </div>

        <form asp-action="Register" method="post">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="auth-errors">
                    <span asp-validation-summary="ModelOnly"></span>
                </div>
            }

            <div class="auth-field">
                <label asp-for="Email">Email Address *</label>
                <input asp-for="Email" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="error-text"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="error-text"></span>
            </div>

            <div class="auth-field">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" placeholder="Repeat your password" />
                <span asp-validation-for="ConfirmPassword" class="error-text"></span>
            </div>

            <button type="submit" class="auth-btn">
                Continue <span>→</span>
            </button>
        </form>

        <p class="auth-note">
            We will send a verification email to your address.
        </p>

        <p class="auth-switch">
            Already a member? <a asp-action="Login">Sign In</a>
        </p>

    </div>
</div>
