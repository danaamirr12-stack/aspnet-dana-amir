@model CoreFitness.Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Sign Up";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-box">

        <h2>Become a Member</h2>
        <p>Sign up to continue your fitness journey with full access to your customized program, training history, and progress tracking. Stay consistent, monitor your development, and keep moving forward with the structure and support built into your account.</p>

        <div class="auth-social">
            <a href="#">G</a>
            <a href="#">f</a>
            <a href="#">⌥</a>
        </div>

        <div class="auth-divider">
            <hr />
            <span>OR CONTINUE WITH</span>
            <hr />
        </div>

        <form asp-action="Register" method="post">

            @if (ViewContext.HttpContext.Request.Method == "POST" && !ViewData.ModelState.IsValid)
            {
                <div class="auth-errors">
                    <span asp-validation-summary="ModelOnly"></span>
                </div>
            }

            <div class="auth-field">
                <label asp-for="Email">Email Address *</label>
                <input asp-for="Email" placeholder="Enter Email Address" />
                <span asp-validation-for="Email" class="error-text"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" placeholder="Enter Password" />
                <span asp-validation-for="Password" class="error-text"></span>
            </div>

            <div class="auth-field">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" placeholder="Repeat Password" />
                <span asp-validation-for="ConfirmPassword" class="error-text"></span>
            </div>

            <button type="submit" class="auth-btn">
                Continue <span>›</span>
            </button>

        </form>

        <p class="auth-note">
            We will send a verification code to your email address.
        </p>

    </div>
</div>