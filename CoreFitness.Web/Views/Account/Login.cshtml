@model CoreFitness.Web.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-box">

        <h2>Welcome Back!</h2>
        <p>Your personalized training hub awaits. Log in to track your workouts and stay on top of your progress.</p>

        <div class="auth-social">
            <a href="#">G</a>
            <a href="#">f</a>
            <a href="#">in</a>
        </div>

        <div class="auth-divider">
            <hr />
            <span>OR USE EMAIL</span>
            <hr />
        </div>

        <form asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="auth-errors">
                    <span asp-validation-summary="ModelOnly"></span>
                </div>
            }

            <div class="auth-field">
                <label asp-for="Email">Email Address *</label>
                <input asp-for="Email" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="error-text"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="error-text"></span>
            </div>

            <button type="submit" class="auth-btn">
                Continue <span>→</span>
            </button>
        </form>

        <p class="auth-note">
            By continuing you accept our <a href="#">terms and conditions</a>
        </p>

        <p class="auth-switch">
            Don't have an account? <a asp-action="Register">Sign Up</a>
        </p>

    </div>
</div>
