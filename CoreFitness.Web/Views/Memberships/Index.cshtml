@{
    ViewData["Title"] = "Memberships";
}

<section class="memberships-hero">
    <h1>Our Membership Offers</h1>
</section>

<section class="memberships-cards">
    <div class="membership-card">
        <div class="membership-icon">⊕</div>
        <h3>Standard Membership</h3>
        <p>With the Standard Membership, get access to our full range of gym facilities.</p>
        <ul class="membership-features">
            <li><span class="feature-dot"></span> Standard Locker</li>
            <li><span class="feature-dot"></span> High-energy group fitness classes</li>
            <li><span class="feature-dot"></span> Motivating & supportive environment</li>
        </ul>
        <div class="membership-price-bar">
            <div>
                <span class="membership-price">495.00</span>
                <span class="membership-period">/monthly</span>
                <p class="membership-classes">* Monthly 20 Classes</p>
            </div>
            <a href="#" class="btn membership-btn">Join Now →</a>
        </div>
        <p class="membership-trial">Try Any Membership Free for 1 Week</p>
    </div>

    <div class="membership-card">
        <div class="membership-icon">⊕</div>
        <h3>Premium Membership</h3>
        <p>With the Premium Membership, get access to our full range of gym facilities.</p>
        <ul class="membership-features">
            <li><span class="feature-dot"></span> Priority Support & Premium Locker</li>
            <li><span class="feature-dot"></span> High-energy group fitness classes</li>
            <li><span class="feature-dot"></span> Motivating & supportive environment</li>
        </ul>
        <div class="membership-price-bar">
            <div>
                <span class="membership-price">595.00</span>
                <span class="membership-period">/monthly</span>
                <p class="membership-classes">* Monthly 20 Classes</p>
            </div>
            <a href="#" class="btn membership-btn">Join Now →</a>
        </div>
        <p class="membership-trial">Try Any Membership Free for 1 Week</p>
    </div>

    <div class="membership-card membership-card-dark">
        <p class="membership-card-tag">Get Your Membership</p>
        <p class="membership-card-sub">Our memberships give you access to all equipment, personalized training.</p>
        <p class="membership-phone">Call Us At: +(46) 8 410 521 00</p>
        <a href="#" class="btn membership-btn-outline">Call Us Today! →</a>
        <div class="membership-card-img">
            <img src="~/images/membershipcurl.png" alt="Membership" />
        </div>
    </div>
</section>

<section class="memberships-benefits">
    <div class="benefit-item">
        <span class="benefit-icon">✓</span>
        <span>Get 30 day free trial</span>
    </div>
    <div class="benefit-item">
        <span class="benefit-icon">✓</span>
        <span>No any hidden fees pay</span>
    </div>
    <div class="benefit-item">
        <span class="benefit-icon">✓</span>
        <span>You can cancel anytime</span>
    </div>
</section>

<section class="faq-section">
    <div class="faq-image">
        <img src="~/images/membershipstraightbar.png" alt="FAQ" />
    </div>
    <div class="faq-content">
        <span class="section-tag">Frequently Asked Questions</span>
        <h2>Common questions about gym and training</h2>
        <div class="faq-list">
            <div class="faq-item active">
                <button class="faq-question">
                    Q1. Do I need prior gym experience to Join CoreFitness?
                    <span class="faq-icon">▲</span>
                </button>
                <div class="faq-answer">
                    <p>No. GymPro is designed for all fitness levels. Our trainers guide beginners with proper techniques and structured workout plans to help them start safely and confidently.</p>
                    <ul>
                        <li>Every new member receives a personalized introduction to equipments</li>
                        <li>Workouts are designed to grow with you, ensuring beginners can start safely.</li>
                    </ul>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question">
                    Q2. What facilities are included with the membership?
                    <span class="faq-icon">▼</span>
                </button>
                <div class="faq-answer" style="display:none">
                    <p>All memberships include access to gym equipment, locker rooms, and group classes.</p>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question">
                    Q3. Can I try them gym before taking a membership?
                    <span class="faq-icon">▼</span>
                </button>
                <div class="faq-answer" style="display:none">
                    <p>Yes, we offer a free 1-week trial for all new members.</p>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question">
                    Q4. Are there group workout programs available?
                    <span class="faq-icon">▼</span>
                </button>
                <div class="faq-answer" style="display:none">
                    <p>Yes, we have a variety of group workout programs available for all fitness levels.</p>
                </div>
            </div>
            <div class="faq-item">
                <button class="faq-question">
                    Q5. Is nutrition guidance included in the plans?
                    <span class="faq-icon">▼</span>
                </button>
                <div class="faq-answer" style="display:none">
                    <p>Premium members get access to nutrition guidance from our certified nutritionists.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('.faq-question').forEach(btn => {
            btn.addEventListener('click', () => {
                const item = btn.parentElement;
                const answer = item.querySelector('.faq-answer');
                const icon = btn.querySelector('.faq-icon');
                const isOpen = item.classList.contains('active');

                document.querySelectorAll('.faq-item').forEach(i => {
                    i.classList.remove('active');
                    i.querySelector('.faq-answer').style.display = 'none';
                    i.querySelector('.faq-icon').textContent = '▼';
                });

                if (!isOpen) {
                    item.classList.add('active');
                    answer.style.display = 'block';
                    icon.textContent = '▲';
                }
            });
        });
    </script>
}