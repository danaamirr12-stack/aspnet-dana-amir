@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="hero-content">
        <span class="hero-tag">Strong Body. Strong Mind.</span>
        <h1>Build Strength Boost<br />Confidence Today!</h1>
        <p>Begin your fitness journey with expert trainers, modern equipment, and a supportive environment designed to help you build strength and confidence.</p>
        <ul class="hero-list">
            <li><span class="hero-check">✓</span> Transform your body with training</li>
            <li><span class="hero-check">✓</span> Personal training for real results</li>
            <li><span class="hero-check">✓</span> Build confidence through fitness</li>
            <li><span class="hero-check">✓</span> Fitness tailored to your goals</li>
        </ul>
        <a href="#" class="btn cf-btn-primary mt-3">Get Started →</a>
    </div>
    <div class="hero-image">
        <img src="~/images/about-us-image-1.png" alt="Hero" />
    </div>
</section>

<section class="partners-bar">
    <div class="partners-logos">
        <span>⊕ Logoipsum</span>
        <span>✳ Logoipsum</span>
        <span>◎ Logoipsum</span>
        <span>⊕ Logoipsum</span>
        <span>⊕ Logoipsum</span>
    </div>
    <span class="partners-title">Modern Equipment</span>
</section>

<section class="about-section">
    <div class="about-images">
        <img src="~/images/about-us-image-1.png" alt="Training" />
        <img src="~/images/about-us-image-2.png" alt="Training" />
    </div>
    <div class="about-content">
        <span class="section-tag">About Us</span>
        <h2>Elevating Fitness Journey with Expert Guidance</h2>
        <p>We support every stage of your fitness journey with certified trainers, personalised programs proven methods designed to help you train safely, build strength.</p>
        <div class="about-quote">
            Our mission is to transform lives by combining expert guidance, powerful training programs, and a motivating community that helps you grow stronger every day.
        </div>
    </div>
</section>

<section class="programs-section">
    <span class="section-tag">Our Programs</span>
    <h2>Professional training program<br />for stronger health</h2>
    <div class="programs-grid">
        <div class="program-card">
            <img src="~/images/program-image-1.png" alt="Program 1" />
        </div>
        <div class="program-card">
            <img src="~/images/program-image-2.png" alt="Program 2" />
        </div>
        <div class="program-card">
            <img src="~/images/program-image-3.png" alt="Program 3" />
        </div>
    </div>
    <p class="section-note">Let's make something great work together. <a href="#">Get Free Quote</a></p>
</section>

<section class="products-section">
    <span class="section-tag">Our Store</span>
    <h2>High quality fitness products<br />built for results</h2>
    <div class="products-grid">
        <img src="~/images/products.png" alt="Products" style="max-width: 900px; width: 100%;" />
    </div>
    <p class="section-note">Let's make something great work together. <a href="#">Get Free Quote</a></p>
</section>