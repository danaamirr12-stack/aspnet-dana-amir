@model IEnumerable<CoreFitness.Domain.Entities.GymClass>
@{
    ViewData["Title"] = "Gymklasser";
}

<h2>Gymklasser</h2>

@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Lägg till klass</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Namn</th>
            <th>Datum & Tid</th>
            <th>Instruktör</th>
            <th>Kategori</th>
            <th>Max platser</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var gymClass in Model)
        {
            <tr>
                <td>@gymClass.Name</td>
                <td>@gymClass.DateTime.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@gymClass.Instructor</td>
                <td>@gymClass.Category</td>
                <td>@gymClass.MaxCapacity</td>
                <td>
                    <form asp-controller="Booking" asp-action="Book" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="gymClassId" value="@gymClass.Id" />
                        <button type="submit" class="btn btn-sm btn-success">Boka</button>
                    </form>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@gymClass.Id" class="btn btn-sm btn-warning">Redigera</a>
                        <a asp-action="Delete" asp-route-id="@gymClass.Id" class="btn btn-sm btn-danger">Ta bort</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>