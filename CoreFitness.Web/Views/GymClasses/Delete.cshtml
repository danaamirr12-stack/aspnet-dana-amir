@model CoreFitness.Domain.Entities.GymClass

@{
    ViewData["Title"] = "Ta bort klass";
}

<h2>Ta bort gymklass</h2>
<p>Är du säker på att du vill ta bort <strong>@Model.Name</strong>?</p>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Ja, ta bort</button>
    <a asp-action="Index" class="btn btn-secondary">Avbryt</a>
</form>